# Drizzle



# PocketBase
# Base URL for server-side access from SvelteKit (no trailing slash)
POCKETBASE_URL="https://pocketbase-production-42e9.up.railway.app"
# Public PocketBase URL for browser-side requests (if needed)
PUBLIC_POCKETBASE_URL="https://pocketbase-production-42e9.up.railway.app"
# Collection for uploaded bottle image records
POCKETBASE_IMAGE_COLLECTION="bottle_images"
# Global bottle catalog collection linked to bottle images
POCKETBASE_BOTTLE_COLLECTION="bottles"
# Alias collection for alternate bottle names
POCKETBASE_ALIAS_COLLECTION="bottle_aliases"
# Auth collection for user login/registration
POCKETBASE_AUTH_COLLECTION="users"

POCKETBASE_ADMIN_EMAIL="change@admin.com"
POCKETBASE_ADMIN_PASSWORD="change_pass"


